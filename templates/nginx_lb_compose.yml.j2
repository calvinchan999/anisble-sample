# Managed by Ansible – do not edit manually
# Docker Compose for the Nginx failover load balancer on {{ inventory_hostname }}

services:
  nginx-lb:
    image: nginx:stable-alpine
    container_name: nginx-lb
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - ./lb.conf:/etc/nginx/conf.d/lb.conf:ro
    # Remove the built-in default.conf so our lb.conf is the only server block.
    # Without this, nginx picks default.conf (server_name localhost) over our
    # catch-all (server_name _) and serves the default page instead of proxying.
    command: >
      sh -c "rm -f /etc/nginx/conf.d/default.conf && exec nginx -g 'daemon off;'"
