services:

  frontend:
    image: frontend:latest
    container_name: frontend
    restart: unless-stopped
    ports:
      - "{{ frontend_port }}:80"
    depends_on:
      - backend

  backend:
    image: backend:latest
    container_name: backend
    restart: unless-stopped
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      DB_HOST: "host.docker.internal"
      DB_PORT: "1433"
      DB_USER: "{{ db_user }}"
      DB_PASS: "{{ db_pass }}"
      DB_NAME: "{{ db_name }}"
      DB_ENCRYPT: "true"
    ports:
      - "{{ backend_port }}:3000"
