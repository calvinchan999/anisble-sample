services:

  frontend:
    image: frontend:latest
    container_name: frontend
    restart: unless-stopped
    ports:
      - "{{ frontend_port }}:80"
    depends_on:
      - backend

  backend:
    image: backend:latest
    container_name: backend
    restart: unless-stopped
    network_mode: host
    environment:
      DB_HOST: "127.0.0.1"
      DB_USER: "{{ db_user }}"
      DB_PASS: "{{ db_pass }}"
      DB_NAME: "{{ db_name }}"
    ports:
      - "{{ backend_port }}:3000"
